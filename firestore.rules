rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'ADMIN';
    }

    function isManager() {
      return isAuthenticated() && (getUserRole() == 'ADMIN' || getUserRole() == 'IT_MANAGER');
    }
    
    function isStaff() {
      return isAuthenticated() && (getUserRole() == 'ADMIN' || getUserRole() == 'IT_MANAGER' || getUserRole() == 'IT_EXECUTIVE' || getUserRole() == 'IT_STAFF');
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      allow create: if isStaff() || (isAuthenticated() && request.auth.uid == userId);
      allow update: if isAuthenticated() && (request.auth.uid == userId || isManager());
      allow delete: if isAdmin();
    }

    // --- SETTINGS COLLECTION ---
    match /settings/{settingId} {
      // Everyone needs to read global settings like Maintenance Mode
      allow read: if isAuthenticated();
      // Only Admins can modify global settings
      allow write: if isAdmin();
    }

    // --- TICKETS COLLECTION ---
    match /tickets/{ticketId} {
      // Employees can only read/write their own tickets
      // IT Staff and Admins can read/write all tickets
      allow read: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isStaff());
      
      // Auth can create for themselves. Staff can create for others (proxy).
      allow create: if isAuthenticated() && (request.resource.data.createdBy == request.auth.uid || isStaff());
      
      // Updates allowed if they own it, or if they are staff
      allow update: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isStaff());
      
      allow delete: if isAdmin();
    }
    
    // --- TICKETS COMMENTS ---
    match /ticketComments/{commentId} {
      // Helpers for comments
      function getTicketData(tId) {
        return get(/databases/$(database)/documents/tickets/$(tId)).data;
      }

      allow read: if isAuthenticated() && (
        isStaff() || 
        (getTicketData(resource.data.ticketId).createdBy == request.auth.uid && !resource.data.isInternalNote)
      );

      allow create: if isAuthenticated() && (
        isStaff() || 
        (getTicketData(request.resource.data.ticketId).createdBy == request.auth.uid && !request.resource.data.isInternalNote)
      );

      allow update, delete: if isAdmin();
    }

    // --- REMINDERS COLLECTION ---
    match /reminders/{reminderId} {
      allow read, write: if isAuthenticated() && (resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
    
    // --- ACTIVITY LOGS COLLECTION ---
    match /activityLogs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isStaff();
      allow update, delete: if isAdmin();
    }
  }
}
